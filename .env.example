# APAGE configuration (spec §33). Copy to .env and adjust.
APP_BASE_DOMAIN=preview.localhost
APP_CONSOLE_DOMAIN=console.localhost
APP_RENDER_DOMAIN=render.preview.localhost

# Ports match docker-compose host mappings (Postgres :5433, MinIO :9100).
DATABASE_URL=postgres://apage:apage@localhost:5433/apage?sslmode=disable
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=http://localhost:9100
# Browser-reachable endpoint used to sign upload/preview URLs. Set when the main
# S3_ENDPOINT is internal-only; enables signed-URL cloud previews (spec §19.3).
S3_PUBLIC_ENDPOINT=
S3_BUCKET=apage
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

JWT_SIGNING_SECRET=dev-jwt-secret-change-me
SESSION_SECRET=dev-session-secret-change-me

AGENT_MIN_PROTOCOL_VERSION=1
AGENT_MIN_VERSION=0.1.0

DIRECT_UPLOAD_MAX_BYTES=8388608
PRESIGN_URL_TTL_SECONDS=900

# SMTP (optional; dev logs emails when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@apage.local

# Abuse governance (V1, spec §15.5)
SAFE_BROWSING_API_KEY=

API_ADDR=:8080
GATEWAY_ADDR=:8090
GATEWAY_INTERNAL_URL=http://localhost:8090
