# APAGE configuration (spec §33). Copy to .env and adjust.
# Cloud-only: object storage (S3/MinIO) is REQUIRED — the api refuses to boot
# without it. APP_ENV=production refuses to boot with the default/empty secrets
# below (SESSION_SECRET, JWT_SIGNING_SECRET, S3 creds).
APP_ENV=development
APP_BASE_DOMAIN=preview.localhost
APP_CONSOLE_DOMAIN=console.localhost
APP_RENDER_DOMAIN=render.preview.localhost
# Parent domain for session/CSRF cookies (e.g. .example.com) so account-gated
# previews on preview subdomains can read the console session. Empty = host-only.
COOKIE_DOMAIN=
# Number of trusted reverse proxies in front of the API. The real client IP is
# read that many hops from the right of X-Forwarded-For so a client cannot spoof
# it. 0 disables X-Forwarded-For trust entirely.
TRUSTED_PROXY_COUNT=1

# Ports match docker-compose host mappings (Postgres :5433, MinIO :9100).
DATABASE_URL=postgres://apage:apage@localhost:5433/apage?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Object storage is REQUIRED (cloud-only mode): the api fails to start without a
# reachable bucket. Defaults below target the docker-compose MinIO.
S3_ENDPOINT=http://localhost:9100
# Browser-reachable endpoint used to sign upload/preview URLs. Set when the main
# S3_ENDPOINT is internal-only; enables signed-URL cloud previews (spec §19.3).
S3_PUBLIC_ENDPOINT=
S3_BUCKET=apage
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
# Bucket lifecycle backstop: expire ALL objects after N days (0=off). Set well
# beyond the longest plan retention so it only ever reaps orphans (spec §19.3).
S3_LIFECYCLE_DAYS=0

JWT_SIGNING_SECRET=dev-jwt-secret-change-me
SESSION_SECRET=dev-session-secret-change-me

DIRECT_UPLOAD_MAX_BYTES=8388608
PRESIGN_URL_TTL_SECONDS=900

# SMTP (optional; dev logs emails when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@apage.local

# Abuse governance (V1, spec §15.5)
SAFE_BROWSING_API_KEY=
# Audit logs older than this are purged daily by the worker (spec §11/§15.6).
AUDIT_RETENTION_DAYS=90

# Platform admin (spec §8). Comma-separated CIDRs/IPs (empty = no IP restriction,
# dev only). Bootstrap seeds the first admin if the table is empty; the admin
# must enroll TOTP MFA on first login.
ADMIN_IP_ALLOWLIST=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# OAuth providers (spec §25). Leave blank to disable a provider. Register the
# callback https://<console>/api/v1/auth/oauth/<provider>/callback with the app.
OAUTH_REDIRECT_BASE=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

API_ADDR=:8080
